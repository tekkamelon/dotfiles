{
  "$schema": "https://opencode.ai/config.json",
  "model": "sakura-ai/preview/Kimi-K2.6",
  "small_model": "sakura-ai/preview/Qwen3.6-35B-A3B",
  "provider": {
	"sakura-ai": {
	  "npm": "@ai-sdk/openai-compatible",
      "name": "sakura aipf",
      "options": {
        "baseURL": "https://api.ai.sakura.ad.jp/v1"
      },
	  "models": {
		"gpt-oss-120b": {},
		"Qwen3-Coder-30B-A3B-Instruct": {},
		"Qwen3-Coder-480B-A35B-Instruct-FP8": {},
		"preview/Kimi-K2.6": {
			"name": "Kimi-K2.6",
			"modalities": { 
				"input":["text", "image"],
				"output":["text"] 
			}
		},
		"preview/Qwen3.6-35B-A3B": {
			"name": "Qwen3.6-35B-A3B",
			"modalities": {
				"input":["text", "image"],
				"output":["text"]
			}
		}
	  }
	}
  },
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ],
      "enabled": false
    },
    "fetch": {
      "type": "local",
      "command": [
		"uvx",
        "mcp-server-fetch"
	  ],
      "enabled": true
    }
  }
}
