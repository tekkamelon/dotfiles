{
  "env": {
    "SAKURA_API_KEY": "${SAKURA_API_KEY}",
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
  },
  "context": {
    "fileName": "AGENTS.md"
  },
  "general": {
    "preferredEditor": "neovim",
    "vimMode": true
  },
  "modelProviders": {
    "openai": [
      {
        "id": "Qwen3-Coder-30B-A3B-Instruct",
        "name": "Qwen 3 Coder 30B A3B Instruct",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "Qwen3-Coder-480B-A35B-Instruct-FP8",
        "name": "Qwen 3 Coder 480B A35B Instruct FP8",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "minimax/minimax-m2.5:free",
        "name": "OpenRouter:Minimax M2.5 Free",
        "envKey": "OPENROUTER_API_KEY",
        "baseUrl": "https://openrouter.ai/api/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "qwen/qwen3.6-35b-a3b",
        "name": "Qwen 3.6 35B A3B",
        "envKey": "OPENROUTER_API_KEY",
        "baseUrl": "https://openrouter.ai/api/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "minimax-m2.5-free",
        "name": "OpenCode Zen:Minimax M2.5 Free",
        "envKey": "OPENCODE_API_KEY",
        "baseUrl": "https://opencode.ai/zen/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      }
    ]
  },
  "$version": 3,
  "model": {
    "name": "Qwen3-Coder-480B-A35B-Instruct-FP8"
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "description": "Brave検索エンジンを使用するMCPサーバー",
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    }
  },
  "ui": {
    "theme": "Qwen Dark"
  }
}
