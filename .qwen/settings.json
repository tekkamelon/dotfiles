{
  "env": {
    "SAKURA_API_KEY": "${SAKURA_API_KEY}",
	"NVIDIA_API_KEY": "${NVIDIA_API_KEY}",
	"BRAVE_API_KEY": "${BRAVE_API_KEY}"
  },
  "context": {
    "fileName": "AGENTS.md"
  },
  "general": {
    "preferredEditor": "neovim",
    "vimMode": true
  },
  "modelProviders": {
    "openai": [
      {
        "id": "Qwen3-Coder-30B-A3B-Instruct",
        "name": "Qwen 3 Coder 30B A3B Instruct",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "Qwen3-Coder-480B-A35B-Instruct-FP8",
        "name": "Qwen 3 Coder 480B A35B Instruct FP8",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "preview/Qwen3.6-35B-A3B",
        "name": "preview/Qwen3.6-35B-A3B",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "preview/Kimi-K2.6",
        "name": "preview/Kimi-K2.6",
        "envKey": "SAKURA_API_KEY",
        "baseUrl": "https://api.ai.sakura.ad.jp/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      },
      {
        "id": "qwen/qwen3.5-122b-a10b",
        "name": "qwen/qwen3.5-122b-a10b",
        "envKey": "NVIDIA_API_KEY",
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "generationConfig": {
          "timeout": 120000,
          "maxRetries": 3,
          "samplingParams": {
            "temperature": 0.3
          }
        }
      }
    ]
  },
  "$version": 4,
  "model": {
    "name": "preview/Qwen3.6-35B-A3B"
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "mcpServers": {
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "description": "Brave検索エンジンを使用するMCPサーバー",
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    }
  },
  "ui": {
    "theme": "Qwen Dark"
  }
}
